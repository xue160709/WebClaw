{
  "manifest_version": 3,
  "name": "OpenClaw Web Assistant",
  "description": "OpenClaw assistant while browsing — side panel chat, quick prompts, and context menu actions. / 逛網頁時於側邊欄與 OpenClaw 代理溝通。",
  "permissions": ["storage", "contextMenus", "activeTab", "sidePanel", "scripting"],
  "host_permissions": ["<all_urls>"],
  "options_ui": {
    "page": "src/pages/options/index.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "OpenClaw Web Assistant",
    "default_icon": {
      "32": "icon-32.png"
    }
  },
  "side_panel": {
    "default_path": "src/pages/panel/index.html"
  },
  "chrome_url_overrides": {
    "newtab": "src/pages/newtab/index.html"
  },
  "icons": {
    "128": "icon-128.png"
  },
  "devtools_page": "src/pages/devtools/index.html",
  "web_accessible_resources": [
    {
      "resources": ["icon-128.png", "icon-32.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
